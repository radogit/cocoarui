{
  "name": "d3_experiment",
  "version": "1.0.0",
  "_main": "index.js",
  "scripts": {
    "build-style-svg-css": "node scripts/build-style-svg-css.js",
    "prestart": "npm run build-style-svg-css",
    "prebuild": "npm run build-style-svg-css",
    "start": "parcel *.html --open --no-cache",
    "dev": "parcel serve index.html --no-cache --dist-dir dist-dev --port 1234 --host 0.0.0.0",
    "clean": "rm -rf .parcel-cache dist",
    "build": "npm run clean && parcel build index.html --dist-dir dist --public-url /cocoarui/",
    "predeploy": "npm run build",
    "deploy": "npm run build && gh-pages -d dist -b gh-pages -r https://github.com/radogit/cocoarui.git && echo \"deployed to: https://radogit.github.io/cocoarui/\" && echo \"check status on: https://github.com/radogit/cocoarui/deployments\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "description": "",
  "homepage": "https://radogit.github.io/cocoarui/",
  "dependencies": {
    "d3": "^7.9.0",
    "live-server": "^1.2.0",
    "parcel": "^2.13.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@parcel/transformer-inline-string": "^2.13.3",
    "gh-pages": "^6.3.0",
    "svgo": "^3.3.2"
  }
}
